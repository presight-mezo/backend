# Mezo Testnet RPC — https://rpc.testnet.mezo.org or your own node
MEZO_RPC_URL=https://rpc.testnet.mezo.org

# Deployer wallet private key — NEVER commit the real value
DEPLOYER_PRIVATE_KEY=0x...

# Fill after deploy
PREDICTION_MARKET_ADDRESS=
GROUP_REGISTRY_ADDRESS=
MANDATE_VALIDATOR_ADDRESS=

# MUSD ERC-20 contract address on Mezo Testnet (get from Mezo docs)
MUSD_ADDRESS=0x...

# Protocol fee wallet — 1% of every resolved market's pool goes here
MEZO_PROTOCOL_FEE_ADDRESS=0x...

# Mezo CDP contract (for onboarding MUSD minting redirect)
MEZO_CDP_ADDRESS=0x...

# Mezo Passport SDK API key (if required)
PASSPORT_SDK_KEY=

# Database (SQLite for local dev, PostgreSQL for Railway)
DATABASE_URL=file:./presight.db

# Express / WebSocket server
PORT=3001
SIWE_DOMAIN=presight.vercel.app
CORS_ORIGIN=https://presight.vercel.app

# Mezo Testnet block explorer API key (for hardhat verify)
MEZO_EXPLORER_API_KEY=
